generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String
  password   String
  role       Role       @default(NURSE)
  isActive   Boolean    @default(true)
  isOnline   Boolean    @default(false)
  avatar     String?
  phone      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  auditLogs  AuditLog[]
  dispatches Dispatch[] @relation("AssignedNurse")
}

model Patient {
  id         String     @id @default(cuid())
  name       String
  address    String
  phone      String
  condition  String
  notes      String?
  createdAt  DateTime   @default(now())
  dispatches Dispatch[]
}

model Dispatch {
  id           String         @id @default(cuid())
  patientId    String
  status       DispatchStatus @default(PENDING)
  priority     Priority       @default(MEDIUM)
  scheduledFor DateTime
  nurseId      String?
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  auditLogs    AuditLog[]
  nurse        User?          @relation("AssignedNurse", fields: [nurseId], references: [id])
  patient      Patient        @relation(fields: [patientId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([nurseId])
  @@index([scheduledFor])
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime  @default(now())
  dispatchId String?
  dispatch   Dispatch? @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

enum Role {
  ADMIN
  NURSE
  DISPATCHER
}

enum DispatchStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
