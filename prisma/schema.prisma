generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  NURSE
  DISPATCHER
}

enum DispatchStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@index([isActive])
  @@index([name])
}

model Specialization {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserSpecialization[]

  @@index([isActive])
  @@index([name])
}

model UserSpecialization {
  userId           String
  specializationId String
  yearsExperience  Int      @default(0)
  createdAt        DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([userId, specializationId])
  @@index([specializationId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  role         Role     @default(NURSE)
  isActive     Boolean  @default(true)
  isOnline     Boolean  @default(false)
  avatar       String?
  phone        String?
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department      Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  specializations UserSpecialization[]
  dispatches      Dispatch[]           @relation("AssignedNurse")
  auditLogs       AuditLog[]

  @@index([role])
  @@index([isActive])
  @@index([departmentId])
}

model Patient {
  id          String   @id @default(cuid())
  name        String
  address     String
  phone       String
  condition   String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  dispatches Dispatch[]

  @@index([name])
  @@index([phone])
}

model Dispatch {
  id           String         @id @default(cuid())
  patientId    String
  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status       DispatchStatus @default(PENDING)
  priority     Priority       @default(MEDIUM)
  scheduledFor DateTime
  nurseId      String?
  nurse        User?          @relation("AssignedNurse", fields: [nurseId], references: [id], onDelete: SetNull)
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  auditLogs AuditLog[]

  @@index([status])
  @@index([priority])
  @@index([nurseId])
  @@index([patientId])
  @@index([scheduledFor])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  previousValue Json?
  newValue   Json?
  details    Json?
  createdAt  DateTime @default(now())
  dispatchId String?
  dispatch   Dispatch? @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
